# Copy this to .env.local for development
# For production: set these in your Vercel dashboard under Project > Settings > Environment Variables
# (GitHub Pages: set the VITE_WORKER_URL repository variable — see .github/workflows/deploy.yml)

# Optional Cloudflare Worker fallback (worker/index.js). When set, the app
# retries via the worker whenever the Alfa LeetCode API rate-limits (429) or
# is unreachable (see src/hooks/useLeetCode.js). Leave unset for Alfa-only.
# Development: local wrangler dev (http://127.0.0.1:8787)
# Production: your deployed workers.dev URL or custom domain
VITE_WORKER_URL=https://leetcode-galaxy-proxy.YOUR_ACCOUNT.workers.dev
