# Copy this to .env.local for development
# For production: set these in your Vercel dashboard under Project > Settings > Environment Variables

# URL of your deployed Cloudflare Worker
# Development: uses local wrangler dev (http://127.0.0.1:8787)
# Production: replace with your deployed workers.dev URL or custom domain
VITE_WORKER_URL=https://leetcode-galaxy-proxy.YOUR_ACCOUNT.workers.dev
