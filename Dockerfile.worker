FROM node:20

WORKDIR /app

# The worker directory alone doesn't have its own node modules yet, 
# so we install wrangler globally inside this container.
RUN npm install -g wrangler

# Copy the worker source
COPY worker/ ./worker/

WORKDIR /app/worker

# Expose local wrangler worker port
EXPOSE 8787

# Run wrangler binding to all networks
CMD ["npx", "wrangler", "dev", "--ip", "0.0.0.0", "--port", "8787"]
